<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="App1.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App1"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <NavigationView x:Name="navigationView"
                    IsBackEnabled="{x:Bind ShellFrame.CanGoBack, Mode=OneWay}"
                    ItemInvoked="on_item_invoked"
                    BackRequested="on_back_requested"
                    IsSettingsVisible="True">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="TestPage1" Tag="TestPage1" Icon="Bookmarks" />
            <NavigationViewItem Content="TestPage2" Tag="TestPage2" Icon="Document" />
        </NavigationView.MenuItems>
        <NavigationView.FooterMenuItems>
            <NavigationViewItem Content="Account" Tag="Account" Icon="Account" />
            <NavigationViewItem Content="Support" Tag="Support" Icon="Help" />
        </NavigationView.FooterMenuItems>
        <!-- ... -->
        <Frame x:Name="ShellFrame" />
    </NavigationView>
</Window>
